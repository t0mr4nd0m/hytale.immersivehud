$C = "../../../Common.ui";

@ProfileLabelStyle         = LabelStyle( FontSize: 14, TextColor: $C.@ColorDefaultLabel, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center );
@ProfileSelectedLabelStyle = LabelStyle( FontSize: 15, TextColor: $C.@ColorGoldHighlight, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center );
@ProfileDescriptionStyle   = LabelStyle( FontSize: 12, TextColor: $C.@ColorDefaultLabel, VerticalAlignment: Center );

@DefaultProfileSelectedBackground = PatchStyle(TexturePath: "../../../Common/HeaderTabSelectedBackground.png", Border: 12);

@ProfileButtonStyle = ButtonStyle(
  Hovered : (Background: @DefaultProfileSelectedBackground),
  Pressed : (Background: @DefaultProfileSelectedBackground),
  Sounds  : $C.@ButtonSounds
);

@ProfileSelectedButtonStyle = ButtonStyle(
  Default : (Background: @DefaultProfileSelectedBackground),
  Hovered : (Background: @DefaultProfileSelectedBackground),
  Pressed : (Background: @DefaultProfileSelectedBackground)
);

Group #ProfileRow {
  LayoutMode: Full;
  Anchor: (Vertical: 4);
  Background: #1a2533(0.6);
  OutlineColor: #3a4a5a(0.35);
  OutlineSize: 1;

  Button #SelectProfileButton {
    Anchor: (Full: 0);
    Style: @ProfileButtonStyle;
    Visible: true;
  }

  Button #SelectedProfile {
    Anchor: (Full: 0);
    Style: @ProfileSelectedButtonStyle;
    Visible: false;
  }

  Group #ProfileButtonContent {
    LayoutMode: Top;
    Anchor: (Full: 0);
    Padding: (Vertical: 8, Horizontal: 16);

    Label #ProfileLabel {
      Text: "#ProfileLabel ";
      Style: @ProfileLabelStyle;
      Visible: true;
    }

    Label #ProfileSelectedLabel {
      Text: "#ProfileSelectedLabel";
      Style: @ProfileSelectedLabelStyle;
      Visible: false;
    }

    Label #ProfileDescription {
      Anchor: (Top: 8, Bottom: 4);
      Text: "Balanced default configuration";
      Style: @ProfileDescriptionStyle;
    }
  }
}