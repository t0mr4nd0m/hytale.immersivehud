$C = "../../../Common.ui";

@ProfileLabelStyle         = LabelStyle( FontSize: 14, TextColor: $C.@ColorDefaultLabel, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center );
@ProfileSelectedLabelStyle = LabelStyle( FontSize: 14, TextColor: $C.@ColorGoldHighlight, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center );
@ProfileDescriptionStyle   = LabelStyle( FontSize: 12, TextColor: $C.@ColorDefaultLabel, VerticalAlignment: Center );

Group #ProfileRow {
  LayoutMode: Left;
  Anchor: (Vertical: 4);
  Padding: (Vertical: 3);
  Background: #1a2533(0.6);
  OutlineColor: #3a4a5a(0.35);
  OutlineSize: 1;

  Group {
    FlexWeight: 1;
    LayoutMode: Top;
    Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);

    Label #ProfileLabel {
      Anchor: (Height: 18);
      Text: "DEFAULT";
      Style: @ProfileLabelStyle;
      Visible: true;
    }

    Label #ProfileSelectedLabel {
      Anchor: (Height: 18);
      Text: "DEFAULT";
      Style: @ProfileSelectedLabelStyle;
      Visible: false;
    }

    Label #ProfileDescription {
      Anchor: (Vertical: 4);
      Text: "Balanced default configuration";
      Style: @ProfileDescriptionStyle;
    }
  }

  $C.@TextButton #ProfileApplyButton {
    Anchor: (Height: 28, Right: 8);
    Text: "SELECT";
  }
}