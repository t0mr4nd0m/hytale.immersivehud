$C = "../../../Common.ui";

@BaseHelpStyle       = LabelStyle( FontSize: 14 );
@SectionLabelStyle   = LabelStyle( FontSize: 14, TextColor: $C.@ColorDefaultLabel, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center );
@ComponentValueStyle = LabelStyle( FontSize: 15, TextColor: $C.@ColorGoldHighlight, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center);

Group #DynamicRulesRoot {
  LayoutMode: Top;
  Padding: (Right: 2);

  $C.@SimpleContainer  #ViewHelpRow {
    Anchor: (Vertical: 8);

    Label #ViewHelpText {
      FlexWeight: 1;
      Text: "Dynamic Triggers copy";
      Style: @BaseHelpStyle;
    }
  }

  Group #DynamicComponentRow {
    LayoutMode: Left;
    Anchor: (Height: 38, Vertical: 4);
    Padding: (Vertical: 8);
    Background: #1a2533(0.6);
    OutlineColor: #3a4a5a(0.35);
    OutlineSize: 1;

    Label #DynamicComponentTitleLabel {
      Anchor: (Width: 220, Height: 32);
      Padding: (Left: 12, Right: 12);
      Text: "SELECTED COMPONENT: ";
      Style: @SectionLabelStyle;
    }

    Label #DynamicComponentValueLabel {
      FlexWeight: 1;
      Anchor: (Height: 32);
      Padding: (Left: 12, Right: 12);
      Text: "Selected component name";
      Style: @ComponentValueStyle;
    }

    Group #DynamicComponentNavHost {
      LayoutMode: Left;
      Anchor: (Width: 260, Height: 28);

      $C.@TextButton #DynamicPrevComponentButton {
        Anchor: (Width: 120, Height: 28);
        Padding: (Left: 8, Right: 8);
        Text: "PREV";
      }

      Panel { Anchor: (Width: 6, Height: 1); }

      $C.@TextButton #DynamicNextComponentButton {
        Anchor: (Width: 120, Height: 28);
        Padding: (Left: 8, Right: 8);
        Text: "NEXT";
      }
    }
  }

  Group #DynamicRulesScrollHost {
    Anchor: (Vertical: 4, Height: 460);
    LayoutMode: TopScrolling;
    ScrollbarStyle: $C.@DefaultScrollbarStyle;

    Group #DynamicRulesList {
      LayoutMode: Top;
    }
  }
}